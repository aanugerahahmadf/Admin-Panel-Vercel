# Exclude large directories
nativephp
nativephp/**
node_modules
node_modules/**
.git
.git/**
.github
.vscode
.idea

# Aggressive vendor optimization (exclude dev and non-essential tools)
vendor/phpstan
vendor/rector
vendor/barryvdh/laravel-ide-helper
vendor/nunomaduro/collision
vendor/pestphp
vendor/fakerphp
vendor/laravel/pint
vendor/laravel/sail
vendor/laravel/pail
vendor/mockery
vendor/phpunit
vendor/myclabs
vendor/phar-io
vendor/theseer
vendor/endroid/qr-code/assets/noto_sans.otf

# Storage and assets - clear them out
storage/logs
storage/logs/**
storage/framework/cache/**
storage/framework/sessions/**
storage/framework/views/**
!storage/app
!storage/framework
!public/build
!public/build/**
!public/storage

# Other large files
_ide_helper*
.phpstorm.meta.php
*.tgz
*.zip
*.tar.gz
logcat_output.txt
docker
stubs
tests
rector.php
phpstan.neon
phpunit.xml
.dockerignore
.editorconfig
docker-compose.yml
Dockerfile
require.log
boost.json
sail

# Keep essential files
!artisan
!composer.json
!composer.lock
!package.json
!package-lock.json
!vercel.json
!.vercelignore
!api
!api/**
!app
!app/**
!bootstrap
!bootstrap/**
!config
!config/**
!database
!database/**
!lang
!lang/**
!public
!public/**
!resources
!resources/**
!routes
!routes/**
