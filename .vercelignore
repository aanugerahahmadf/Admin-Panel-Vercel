# Exclude EVERYTHING that Vercel should build/install
node_modules
vendor

# Core Exclusions
.git
.github
.vscode
.idea

# Laravel / PHP overhead
tests
tests/**
storage/app/**
storage/framework/cache/**
storage/framework/sessions/**
storage/framework/views/**
storage/logs/**
docker
docker/**
stubs
stubs/**

# Static Asset source (only need built files in public/build)
resources/css/**
resources/js/**

# NativePHP overhead
native
native/**
nativephp
nativephp/**

# Documentation and meta
*.md
_ide_helper*
rector.php
sail
server.php
logcat_output.txt
boost.json
artisan
package-lock.json
vite.config.js
build.sh
phpunit.xml
.editorconfig
.dockerignore
.gitattributes
.phpstorm.meta.php



